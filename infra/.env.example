# SampleTech Local Dev — Environment Variables
# Copy to infra/.env and fill in values. Never commit .env.

# PostgreSQL
POSTGRES_USER=sampletech
POSTGRES_PASSWORD=<choose_a_strong_local_password>
POSTGRES_DB=sampletech
POSTGRES_PORT=5432

# JWT signing key — must be at least 32 characters
JWT_KEY=<generate_with: openssl rand -base64 48>

# Optional overrides
API_PORT=5000
FRONTEND_PORT=4200
